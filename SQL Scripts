CREATE TABLE `users` (
  `id` int(11) NOT NULL AUTO_INCREMENT,
  `is_admin` tinyint(1) NOT NULL DEFAULT '0',
  `name` varchar(100) NOT NULL,
  `password` tinytext NOT NULL,
  `credits` int(11) NOT NULL DEFAULT '0',
  `hack_chance` int(11) NOT NULL DEFAULT '50',
  `is_hacker` tinyint(1) NOT NULL DEFAULT '0',
  `hack_cooldown` timestamp NULL DEFAULT NULL,
  `last_hacked` timestamp NULL DEFAULT NULL,
  `last_hacker` tinytext,
  `is_corp` tinyint(1) NOT NULL DEFAULT '0',
  `warning_seen` tinyint(4) DEFAULT NULL,
  PRIMARY KEY (`id`),
  UNIQUE KEY `name` (`name`)
);


CREATE TABLE `variables` (
  `ID` int(11) DEFAULT NULL,
  `Name` varchar(255) DEFAULT NULL,
  `Value` varchar(255) DEFAULT NULL
);
